      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (target, payload_status) (rate(receiver_webhook_requests_total[1m]))",
          "legendFormat": "{{target}} {{payload_status}}",
          "refId": "A"
        }
      ],
      "title": "Webhook RPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (target, outcome) (rate(receiver_yandex_send_total[1m]))",
          "legendFormat": "{{target}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Yandex Send Outcomes (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, target) (rate(receiver_yandex_send_latency_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p50 {{target}}",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, target) (rate(receiver_yandex_send_latency_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p95 {{target}}",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, target) (rate(receiver_yandex_send_latency_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p99 {{target}}",
          "refId": "C"
        }
      ],
      "title": "Yandex Send Latency (success)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (target) (rate(receiver_yandex_send_total{outcome!=\"success\"}[5m])) / clamp_min(sum by (target) (rate(receiver_yandex_send_total[5m])), 1e-9)",
          "legendFormat": "{{target}} error_ratio",
          "refId": "A"
        }
      ],
      "title": "Yandex Send Error Ratio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "value" },
      "targets": [
